#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
GUNICORN="$ROOT/.venv/bin/gunicorn"
PYTHON="$ROOT/.venv/bin/python"
REQUIREMENTS="$ROOT/requirements.txt"
INSTANCE="$ROOT/instance"
REQUIREMENTS_STAMP="$INSTANCE/requirements.sha256"
PIDFILE="$INSTANCE/twn-toolkit.pid"
SCHEME_FILE="$INSTANCE/twn-toolkit.scheme"
HOST_FILE="$INSTANCE/twn-toolkit.host"
PORT_FILE="$INSTANCE/twn-toolkit.port"
AUTOMATION_PIDFILE="$INSTANCE/twn-automation.pid"
ACCESS_LOG="$INSTANCE/twn-toolkit-access.log"
ERROR_LOG="$INSTANCE/twn-toolkit-error.log"
AUTOMATION_LOG="$INSTANCE/twn-automation.log"
SERVER_SETTINGS="$INSTANCE/server_settings.json"
PREVIOUS_SERVER_SETTINGS="$INSTANCE/server_settings.previous.json"
TLS_DIR="$INSTANCE/tls"
TLS_CERT_DEFAULT="$TLS_DIR/cert.pem"
TLS_KEY_DEFAULT="$TLS_DIR/key.pem"
TLS_ENABLED_FILE="$TLS_DIR/enabled"
REQUESTED_HOST=${TWN_TOOLKIT_HOST:-}
REQUESTED_PORT=${TWN_TOOLKIT_PORT:-}
HOST=$REQUESTED_HOST
PREFERRED_HOST=${TWN_TOOLKIT_DISPLAY_HOST:-}
PORT=${TWN_TOOLKIT_PORT:-5050}
WORKERS=${TWN_TOOLKIT_WORKERS:-2}
STOP_TIMEOUT=${TWN_TOOLKIT_STOP_TIMEOUT:-10}
TLS_CERT=${TWN_TOOLKIT_CERTFILE:-}
TLS_KEY=${TWN_TOOLKIT_KEYFILE:-}
SCHEME=http

if [ -z "$HOST" ] && [ -f "$SERVER_SETTINGS" ]; then
  HOST=$(python3 -c '
import json
import sys
try:
    with open(sys.argv[1], encoding="utf-8") as handle:
        value = json.load(handle).get("listen_host", "127.0.0.1")
except (OSError, ValueError):
    value = "0.0.0.0"
print(value if value in {"127.0.0.1", "0.0.0.0"} else "0.0.0.0")
' "$SERVER_SETTINGS")
fi
HOST=${HOST:-0.0.0.0}
if [ -z "$PREFERRED_HOST" ] && [ -f "$SERVER_SETTINGS" ]; then
  PREFERRED_HOST=$(python3 -c '
import json, sys
try:
    with open(sys.argv[1], encoding="utf-8") as handle:
        print(str(json.load(handle).get("preferred_fqdn", "")).strip())
except (OSError, ValueError):
    print("")
' "$SERVER_SETTINGS")
fi
DISPLAY_HOST=${PREFERRED_HOST:-$HOST}
if [ "$DISPLAY_HOST" = "0.0.0.0" ]; then
  DISPLAY_HOST="127.0.0.1"
fi

load_running_endpoint() {
  if [ -z "$REQUESTED_HOST" ] && [ -f "$HOST_FILE" ]; then
    HOST=$(cat "$HOST_FILE")
  fi
  if [ -z "$REQUESTED_PORT" ] && [ -f "$PORT_FILE" ]; then
    PORT=$(cat "$PORT_FILE")
  fi
}

show_access_urls() {
  "$PYTHON" -c '
import ipaddress
import re
import socket
import subprocess
import sys

scheme, host, port, preferred = sys.argv[1:]
addresses = set()

def add(value):
    value = value.strip()
    try:
        address = ipaddress.ip_address(value)
    except ValueError:
        return
    if address.version == 4 and not address.is_unspecified and not address.is_multicast and not address.is_link_local:
        addresses.add(str(address))

if host == "0.0.0.0":
    for command in (("ip", "-o", "-4", "addr", "show", "up"), ("ifconfig",)):
        try:
            output = subprocess.run(command, capture_output=True, text=True, timeout=3, check=True).stdout
        except (FileNotFoundError, OSError, subprocess.SubprocessError):
            continue
        pattern = r"\binet\s+(\d+\.\d+\.\d+\.\d+)"
        for match in re.findall(pattern, output):
            add(match)
    try:
        for answer in socket.getaddrinfo(socket.gethostname(), None, socket.AF_INET):
            add(answer[4][0])
    except socket.gaierror:
        pass
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as probe:
            probe.connect(("192.0.2.1", 9))
            add(probe.getsockname()[0])
    except OSError:
        pass
else:
    add(host)

ordered = sorted((value for value in addresses if value != "127.0.0.1"), key=ipaddress.ip_address)
ordered.append("127.0.0.1")
urls = []
if preferred:
    urls.append(f"{scheme}://{preferred}:{port}")
urls.extend(f"{scheme}://{address}:{port}" for address in ordered)
urls = list(dict.fromkeys(urls))
print("Toolkit access URLs:")
for url in urls:
    print(f"  {url}")
' "$SCHEME" "$HOST" "$PORT" "$PREFERRED_HOST"
}

configure_tls() {
  if { [ -n "$TLS_CERT" ] && [ -z "$TLS_KEY" ]; } || { [ -z "$TLS_CERT" ] && [ -n "$TLS_KEY" ]; }; then
    echo "Set both TWN_TOOLKIT_CERTFILE and TWN_TOOLKIT_KEYFILE, or neither." >&2
    exit 1
  fi
  if [ -z "$TLS_CERT" ] && [ -f "$TLS_ENABLED_FILE" ]; then
    TLS_CERT="$TLS_CERT_DEFAULT"
    TLS_KEY="$TLS_KEY_DEFAULT"
  fi
  if [ -n "$TLS_CERT" ]; then
    if ! "$PYTHON" -c 'from twn_toolkit.tls_tools import validate_certificate_pair; import sys; validate_certificate_pair(sys.argv[1], sys.argv[2])' "$TLS_CERT" "$TLS_KEY"; then
      echo "HTTPS is enabled, but its certificate or private key is invalid." >&2
      echo "Run: ./twn disable-https" >&2
      exit 1
    fi
    SCHEME=https
  fi
}

is_running() {
  [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

automation_is_running() {
  [ -f "$AUTOMATION_PIDFILE" ] && kill -0 "$(cat "$AUTOMATION_PIDFILE")" 2>/dev/null
}

start_automation() {
  if automation_is_running; then
    return
  fi
  rm -f "$AUTOMATION_PIDFILE"
  cd "$ROOT"
  "$PYTHON" -m twn_toolkit.automation_worker \
    --instance "$INSTANCE" \
    --daemon \
    --pid-file "$AUTOMATION_PIDFILE" \
    --log-file "$AUTOMATION_LOG"
  attempts=0
  while [ "$attempts" -lt 20 ]; do
    if automation_is_running; then
      return
    fi
    attempts=$((attempts + 1))
    sleep 0.1
  done
  echo "The automation scheduler did not start. Check: $AUTOMATION_LOG" >&2
  return 1
}

stop_automation() {
  if ! automation_is_running; then
    rm -f "$AUTOMATION_PIDFILE"
    return
  fi
  automation_pid=$(cat "$AUTOMATION_PIDFILE")
  kill "$automation_pid"
  attempts=0
  while kill -0 "$automation_pid" 2>/dev/null && [ "$attempts" -lt 50 ]; do
    attempts=$((attempts + 1))
    sleep 0.1
  done
  if kill -0 "$automation_pid" 2>/dev/null; then
    kill -KILL "$automation_pid" 2>/dev/null || true
  fi
  rm -f "$AUTOMATION_PIDFILE"
}

requirements_hash() {
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$REQUIREMENTS" | awk '{print $1}'
  elif command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$REQUIREMENTS" | awk '{print $1}'
  else
    "$PYTHON" -c 'import hashlib, pathlib, sys; print(hashlib.sha256(pathlib.Path(sys.argv[1]).read_bytes()).hexdigest())' "$REQUIREMENTS"
  fi
}

ensure_requirements() {
  if [ ! -x "$PYTHON" ]; then
    echo "Python virtual environment is missing. Run: ./install.sh" >&2
    exit 1
  fi
  mkdir -p "$INSTANCE"
  current_hash=$(requirements_hash)
  previous_hash=""
  if [ -f "$REQUIREMENTS_STAMP" ]; then
    previous_hash=$(cat "$REQUIREMENTS_STAMP")
  fi
  if [ "$current_hash" != "$previous_hash" ]; then
    echo "Installing updated toolkit requirements..."
    "$PYTHON" -m pip install -r "$REQUIREMENTS"
    printf "%s\n" "$current_hash" > "$REQUIREMENTS_STAMP"
  fi
}

port_available() {
  "$ROOT/.venv/bin/python" -c '
import socket
import sys

host, port = sys.argv[1], int(sys.argv[2])
family = socket.AF_INET6 if ":" in host else socket.AF_INET
with socket.socket(family, socket.SOCK_STREAM) as listener:
    listener.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    listener.bind((host, port))
' "$HOST" "$PORT" >/dev/null 2>&1
}

has_instance_permission_issues() {
  [ -d "$INSTANCE" ] || return 1
  if [ ! -r "$INSTANCE" ] || [ ! -w "$INSTANCE" ]; then
    return 0
  fi
  for path in "$INSTANCE"/*; do
    [ -e "$path" ] || continue
    if [ ! -r "$path" ] || [ ! -w "$path" ]; then
      return 0
    fi
  done
  return 1
}

show_instance_permission_issues() {
  echo "The instance directory has files this user cannot read or write:" >&2
  if [ ! -r "$INSTANCE" ] || [ ! -w "$INSTANCE" ]; then
    echo "  $INSTANCE" >&2
  fi
  for path in "$INSTANCE"/*; do
    [ -e "$path" ] || continue
    if [ ! -r "$path" ] || [ ! -w "$path" ]; then
      echo "  $path" >&2
    fi
  done
}

offer_permission_repair() {
  show_instance_permission_issues
  echo "This often happens after running: sudo ./twn start" >&2
  if [ "$(id -u)" -eq 0 ]; then
    echo "Run: ./twn fix-permissions" >&2
    return 1
  fi
  if [ -t 0 ] && command -v sudo >/dev/null 2>&1; then
    printf "Run sudo ./twn fix-permissions now? [y/N] "
    read -r answer
    case "$answer" in
      y|Y|yes|YES)
        sudo "$0" fix-permissions
        return
        ;;
    esac
  fi
  echo "Run: sudo $0 fix-permissions" >&2
  return 1
}

start() {
  if is_running; then
    load_running_endpoint
    if [ -f "$SCHEME_FILE" ]; then
      SCHEME=$(cat "$SCHEME_FILE")
    fi
    start_automation
    echo "The WiFi Ninja's Toolkit is already running (PID $(cat "$PIDFILE"))."
    echo "Automation scheduler is running (PID $(cat "$AUTOMATION_PIDFILE"))."
    show_access_urls
    return
  fi

  if [ "$(id -u)" -ne 0 ] && has_instance_permission_issues; then
    offer_permission_repair
    if has_instance_permission_issues; then
      exit 1
    fi
  fi

  ensure_requirements
  configure_tls

  if [ ! -x "$GUNICORN" ]; then
    echo "Gunicorn is not installed. Run: .venv/bin/pip install -r requirements.txt" >&2
    exit 1
  fi

  if ! port_available; then
    echo "Cannot start: $HOST:$PORT is already in use." >&2
    echo "A previous server may still be shutting down. Wait a moment and run ./twn status." >&2
    exit 1
  fi

  mkdir -p "$INSTANCE"
  rm -f "$PIDFILE"
  cd "$ROOT"
  set -- "$GUNICORN" \
    --bind "$HOST:$PORT" \
    --workers "$WORKERS" \
    --timeout 3700 \
    --pid "$PIDFILE" \
    --access-logfile "$ACCESS_LOG" \
    --error-logfile "$ERROR_LOG" \
    --capture-output \
    --daemon
  if [ "$SCHEME" = "https" ]; then
    set -- "$@" --certfile "$TLS_CERT" --keyfile "$TLS_KEY"
    export TWN_TOOLKIT_HTTPS=1
  else
    unset TWN_TOOLKIT_HTTPS 2>/dev/null || true
  fi
  set -- "$@" "twn_toolkit:create_app()"
  "$@"

  attempts=0
  while [ "$attempts" -lt 30 ]; do
    if is_running; then
      start_automation
      echo "Started The WiFi Ninja's Toolkit (PID $(cat "$PIDFILE"))."
      echo "Started automation scheduler (PID $(cat "$AUTOMATION_PIDFILE"))."
      printf "%s\n" "$SCHEME" > "$SCHEME_FILE"
      printf "%s\n" "$HOST" > "$HOST_FILE"
      printf "%s\n" "$PORT" > "$PORT_FILE"
      show_access_urls
      return
    fi
    attempts=$((attempts + 1))
    sleep 0.1
  done

  echo "The server did not start." >&2
  if has_instance_permission_issues; then
    offer_permission_repair
  fi
  echo "Check: ./twn logs" >&2
  exit 1
}

stop() {
  if ! is_running; then
    rm -f "$PIDFILE"
    rm -f "$SCHEME_FILE"
    stop_automation
    echo "The WiFi Ninja's Toolkit is not running."
    return
  fi

  stop_automation
  pid=$(cat "$PIDFILE")
  kill "$pid"
  attempts=0
  max_attempts=$((STOP_TIMEOUT * 10))
  while kill -0 "$pid" 2>/dev/null && [ "$attempts" -lt "$max_attempts" ]; do
    attempts=$((attempts + 1))
    sleep 0.1
  done
  if kill -0 "$pid" 2>/dev/null; then
    echo "Graceful stop timed out after ${STOP_TIMEOUT}s; forcing shutdown (PID $pid)." >&2
    children=$(pgrep -P "$pid" 2>/dev/null || true)
    if [ -n "$children" ]; then
      kill -KILL $children "$pid" 2>/dev/null || true
    else
      kill -KILL "$pid" 2>/dev/null || true
    fi
    attempts=0
    while kill -0 "$pid" 2>/dev/null && [ "$attempts" -lt 50 ]; do
      attempts=$((attempts + 1))
      sleep 0.1
    done
    if kill -0 "$pid" 2>/dev/null; then
      echo "The server could not be stopped (PID $pid)." >&2
      echo "Its PID file was retained; inspect the process manually." >&2
      return 1
    fi
  fi
  rm -f "$PIDFILE"
  rm -f "$SCHEME_FILE"
  rm -f "$HOST_FILE"
  rm -f "$PORT_FILE"
  echo "Stopped The WiFi Ninja's Toolkit."
}

status() {
  if is_running; then
    load_running_endpoint
    if [ -f "$SCHEME_FILE" ]; then
      SCHEME=$(cat "$SCHEME_FILE")
    fi
    echo "The WiFi Ninja's Toolkit is running (PID $(cat "$PIDFILE"))."
    if automation_is_running; then
      echo "Automation scheduler is running (PID $(cat "$AUTOMATION_PIDFILE"))."
    else
      echo "Automation scheduler is not running." >&2
    fi
    show_access_urls
  else
    echo "The WiFi Ninja's Toolkit is not running."
    exit 1
  fi
}

enable_https() {
  ensure_requirements
  restart_after=0
  if is_running; then
    restart_after=1
    stop
  fi
  if [ -f "$TLS_CERT_DEFAULT" ] || [ -f "$TLS_KEY_DEFAULT" ]; then
    if [ ! -f "$TLS_CERT_DEFAULT" ] || [ ! -f "$TLS_KEY_DEFAULT" ]; then
      echo "The local TLS certificate pair is incomplete. Inspect: $TLS_DIR" >&2
      exit 1
    fi
    if [ "$#" -gt 0 ]; then
      echo "A local certificate already exists; additional names cannot be added without regenerating it." >&2
      echo "Certificate management and safe rotation will be added in a later phase." >&2
      exit 1
    fi
    "$PYTHON" -c 'from twn_toolkit.tls_tools import validate_certificate_pair; import sys; validate_certificate_pair(sys.argv[1], sys.argv[2])' "$TLS_CERT_DEFAULT" "$TLS_KEY_DEFAULT"
    touch "$TLS_ENABLED_FILE"
    chmod 600 "$TLS_ENABLED_FILE"
    echo "HTTPS re-enabled with the existing local certificate."
    if [ "$restart_after" -eq 1 ]; then
      start
    else
      echo "Start with: ./twn start"
    fi
    return
  fi
  "$PYTHON" -c '
import sys
import json
from pathlib import Path
from twn_toolkit.tls_tools import generate_self_signed_certificate
instance = Path(sys.argv[1])
extra_names = list(sys.argv[2:])
try:
    settings = json.loads((instance / "server_settings.json").read_text(encoding="utf-8"))
except (OSError, ValueError):
    settings = {}
extra_names.extend([settings.get("instance_name", ""), settings.get("preferred_fqdn", "")])
cert, key = generate_self_signed_certificate(instance, extra_names=extra_names)
print(f"Created self-signed certificate: {cert}")
print(f"Created private key: {key}")
' "$INSTANCE" "$@"
  echo "HTTPS enabled. Browsers will warn until this self-signed certificate is trusted."
  if [ "$restart_after" -eq 1 ]; then
    start
  else
    echo "Start with: ./twn start"
  fi
}

disable_https() {
  restart_after=0
  if is_running; then
    restart_after=1
    stop
  fi
  rm -f "$TLS_ENABLED_FILE"
  echo "HTTPS disabled. The certificate and key were retained for future use."
  if [ "$restart_after" -eq 1 ]; then
    start
  fi
}

logs() {
  if [ -f "$ERROR_LOG" ]; then
    tail -n 100 "$ERROR_LOG"
  else
    echo "No server log exists yet."
  fi
  if [ -f "$AUTOMATION_LOG" ]; then
    echo "Automation scheduler log:"
    tail -n 100 "$AUTOMATION_LOG"
  fi
}

fix_permissions() {
  if is_running; then
    echo "Stop the toolkit before repairing instance permissions: ./twn stop" >&2
    exit 1
  fi
  if [ ! -d "$INSTANCE" ]; then
    echo "No instance directory exists yet."
    return
  fi
  owner=$(id -un)
  group=$(id -gn)
  if [ "$(id -u)" -ne 0 ]; then
    echo "Repairing files created by sudo mode requires elevated permissions."
    echo "Run: sudo $0 fix-permissions"
    exit 1
  fi
  if [ -n "${SUDO_USER:-}" ]; then
    owner="$SUDO_USER"
    group=$(id -gn "$SUDO_USER")
  fi
  chown -R "$owner:$group" "$INSTANCE"
  echo "Repaired instance permissions for $owner:$group."
}

reset_auth() {
  if is_running; then
    echo "Stop the toolkit before resetting authentication: ./twn stop" >&2
    exit 1
  fi
  if [ ! -f "$INSTANCE/auth.json" ]; then
    echo "Authentication is already unconfigured."
    return
  fi
  printf "Delete all toolkit users and require first-launch setup again? [y/N] "
  read -r answer
  case "$answer" in
    y|Y|yes|YES)
      rm -f "$INSTANCE/auth.json"
      echo "Authentication reset. Run ./twn start, then open the toolkit to create a new administrator."
      ;;
    *)
      echo "Reset cancelled."
      ;;
  esac
}

reset_data() {
  if is_running; then
    echo "Stop the toolkit before resetting saved profile data: ./twn stop" >&2
    exit 1
  fi
  ensure_requirements
  cd "$ROOT"
  "$PYTHON" -m flask --app twn_toolkit reset-data "$@"
}

web_restart() {
  sleep 2
  if "$0" restart; then
    rm -f "$PREVIOUS_SERVER_SETTINGS"
    return
  fi

  echo "Restart with new server settings failed; restoring the previous settings." >&2
  if [ -f "$PREVIOUS_SERVER_SETTINGS" ]; then
    cp "$PREVIOUS_SERVER_SETTINGS" "$SERVER_SETTINGS"
  fi
  if "$0" start; then
    rm -f "$PREVIOUS_SERVER_SETTINGS"
  fi
}

case "${1:-}" in
  start)
    start
    ;;
  stop)
    stop
    ;;
  restart)
    stop
    start
    ;;
  status)
    status
    ;;
  logs)
    logs
    ;;
  fix-permissions)
    fix_permissions
    ;;
  adminreset|reset-auth)
    reset_auth
    ;;
  reset-data)
    shift
    reset_data "$@"
    ;;
  web-restart)
    web_restart
    ;;
  enable-https)
    shift
    enable_https "$@"
    ;;
  disable-https)
    disable_https
    ;;
  *)
    echo "Usage: ./twn {start|stop|restart|status|logs|enable-https|disable-https|fix-permissions|adminreset|reset-data}" >&2
    exit 2
    ;;
esac
